rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to validate email format (gmail)
    function isValidGmailEmail(email) {
      return email.matches('^[a-zA-Z0-9._%-]+@gmail\\.com$');
    }

    // Allow authenticated users to read/write their own user document
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      
      // Allow write (create) only if:
      // - User is creating their own document
      // - Email is valid gmail format
      // - Email is lowercase
      allow create: if request.auth.uid == userId
        && isValidGmailEmail(request.resource.data.email)
        && request.resource.data.email == request.resource.data.email.lower()
        && request.resource.data.uid == userId
        && request.resource.data.get('createdAt', null) != null;
      
      // Allow update only if:
      // - User is updating their own document
      // - Email cannot be changed after creation
      allow update: if request.auth.uid == userId
        && resource.data.email == request.resource.data.email
        && request.resource.data.get('updatedAt', null) != null;
      
      allow delete: if false; // Prevent document deletion
    }
    
    // Index collection for checking email uniqueness
    match /emails/{emailDoc} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }
    
    // Allow authenticated users to read/write community posts
    match /communityPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }
    
    // Allow authenticated users to read/write community comments
    match /communityPosts/{postId}/comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }
    
    // Allow authenticated users to read/write their period data
    match /periodData/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
